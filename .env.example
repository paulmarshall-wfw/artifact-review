# Artifact Review local development configuration.
# Do not put real secrets in this file.

ARTIFACT_REVIEW_SERVICE_HOST=127.0.0.1
ARTIFACT_REVIEW_SERVICE_PORT=4794
VITE_ARTIFACT_REVIEW_API_BASE=http://127.0.0.1:4794

DATABASE_URL=postgres://artifact_review:artifact_review@localhost:5432/artifact_review_dev
INVOKE_PROVIDERS_REGISTRY_URL=http://127.0.0.1:5181

# First-run bootstrap only. A saved selectedProviderProfileKey takes priority.
INVOKE_PROVIDERS_PROFILE=

# Use only in tests or explicit demos.
ARTIFACT_REVIEW_DEMO_PROVIDER_MODE=false

LOG_LEVEL=info
