{
  "name": "artifact-review",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n service,ui \"npm run dev:service\" \"npm run dev:web\"",
    "dev:web": "vite --host 127.0.0.1 --port 5182 --strictPort",
    "dev:service": "tsx watch service/src/index.ts",
    "tauri:dev": "concurrently -k -n service,tauri \"npm run dev:service\" \"tauri dev\"",
    "build": "tsc -p tsconfig.json && vite build",
    "build:service": "tsc -p service/tsconfig.json",
    "build:tauri": "tauri build",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p service/tsconfig.json --noEmit",
    "verify": "npm run lint && npm run test && npm run build",
    "doctor": "node scripts/doctor.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "2.5.0",
    "cors": "2.8.5",
    "express": "5.1.0",
    "pg": "8.16.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.5.0",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.3",
    "@types/node": "22.15.30",
    "@types/pg": "8.15.4",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.5.2",
    "concurrently": "9.1.2",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "vite": "6.3.5",
    "vitest": "3.2.4"
  }
}
